# Environment: development | production
APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=qr_bazaar

# Secrets (generate with: openssl rand -hex 32)
QR_SECRET=change-me-use-openssl-rand-hex-32
SESSION_SECRET=change-me-use-openssl-rand-hex-32

# Chapa payment gateway
CHAPA_ENABLED=true
CHAPA_MODE=test
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-your_public_key
CHAPA_SECRET_KEY=CHASECK_TEST-your_secret_key
CHAPA_ENCRYPTION_KEY=your_encryption_key
CHAPA_TICKET_FEE_ETB=25
CHAPA_ROLE_REQUEST_FEE_ETB=79
CHAPA_SELLER_EVENT_FEE_ETB=99
CHAPA_PROMO_FEE_ETB=120

# Cursor SDK AI assist (Node.js 18+ required)
CURSOR_ENABLED=true
CURSOR_API_KEY=your_cursor_api_key
CURSOR_MODEL=composer-2
